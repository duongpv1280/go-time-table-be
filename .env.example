# Server
SERVER_PORT=8080

# DB_DRIVER selects the database backend.
# Valid values: sqlite (default), mysql
DB_DRIVER=sqlite

# SQLite — used when DB_DRIVER=sqlite
DB_PATH=gorm.db

# MySQL — used when DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=timetable
# DB_USER=root
# DB_PASSWORD=password

# JWT
JWT_SECRET=your-secret-key-here
